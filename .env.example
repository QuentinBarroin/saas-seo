# ----- runtime -----
NODE_ENV=development

# ----- database (Supabase Postgres) -----
# Pooler connection (utilisée par Prisma client en runtime app)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (utilisée par les migrations Prisma)
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-eu-west-3.pooler.supabase.com:5432/postgres"

# ----- supabase auth -----
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
# Nouveau naming Supabase (2025+) : publishable key (sb_publishable_*). Prime sur ANON_KEY.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
# Legacy : anon key (eyJ... JWT). Conservé en fallback pour les projets antérieurs.
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ----- inngest -----
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ----- encryption (32 bytes hex) -----
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# ----- anthropic (claude sonnet 4.6 par défaut) -----
ANTHROPIC_API_KEY=""

# ----- google oauth (pour GSC) -----
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3434/api/integrations/google/callback"

# ----- dataforseo (peut être stocké chiffré côté projet à la place) -----
# Optionnel en local pour tests. En prod, chaque projet stocke ses creds dans la DB chiffrés.
DATAFORSEO_LOGIN=""
DATAFORSEO_PASSWORD=""

# ----- audit caps (step serp S2-05 + backlog S2-11) -----
# Nombre max de keywords seed à requêter par audit (protection budget)
MAX_KEYWORDS_PER_AUDIT=50
# Budget max DataForSEO par audit en USD (protection explosion coût)
MAX_DATAFORSEO_USD_PER_AUDIT=0.5
# Budget max Anthropic par audit en USD (protection explosion coût)
MAX_ANTHROPIC_USD_PER_AUDIT=0.5
# Nombre max de lignes GSC importées par audit (step import-gsc S2-03 — l'API GSC est
# gratuite mais quota-limitée ; ce cap évite d'importer un volume disproportionné)
MAX_GSC_ROWS_PER_AUDIT=100000
